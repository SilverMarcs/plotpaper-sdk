{
  "name": "@plotpaper/cli",
  "version": "0.1.0",
  "description": "CLI for validating, bundling, and submitting Plotpaper mini apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "plotpaper": "./bin/plotpaper.js",
    "plotpaper-cli": "./bin/plotpaper.js"
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@plotpaper/core": "^0.1.0",
    "commander": "^12.0.0",
    "esbuild": "^0.21.0",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/plotpaper/plotpaper-sdk"
  },
  "keywords": ["plotpaper", "mini-app", "cli", "bundler"]
}
